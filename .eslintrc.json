{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "@typescript-eslint/no-unused-vars": "error",
    "@typescript-eslint/no-explicit-any": "warn",
    "@next/next/no-img-element": "error",
    "no-console": ["warn", { "allow": ["error"] }],
    "prefer-const": "error"
  }
}
