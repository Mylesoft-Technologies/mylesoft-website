# Mylesoft Technologies Website Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.mylesoft.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/mylesoft"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@mylesoft.com
RESEND_AUDIENCE_ID="your_resend_audience_id_here"

# Analytics
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
POSTHOG_API_KEY="phc_your_posthog_api_key_here"
VERCEL_ANALYTICS_ID="your_vercel_analytics_id"
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Search (Algolia)
ALGOLIA_APP_ID="your_algolia_app_id_here"
ALGOLIA_API_KEY="your_algolia_api_key_here"
ALGOLIA_SEARCH_API_KEY="your_algolia_search_api_key_here"
ALGOLIA_ADMIN_KEY="your_algolia_admin_key_here"
NEXT_PUBLIC_ALGOLIA_APP_ID="your_public_algolia_app_id"
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY="your_public_algolia_search_key"

# Maps (Google Maps)
GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Live Chat (Crisp)
CRISP_WEBSITE_ID="your_crisp_website_id_here"
INTERCOM_APP_ID="your_intercom_app_id_here"
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Scheduling (Cal.com)
CALCOM_API_KEY="your_calcom_api_key_here"
CALCOM_EVENT_TYPE_ID="your_calcom_event_type_id_here"
CAL_API_KEY=cal_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CAL_EVENT_TYPE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# File Storage
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret_here"

# Monitoring
SENTRY_DSN="https://your_sentry_dsn_here"
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxx.ingest.sentry.io/xxxxxxx

# Social Media
LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"
TWITTER_API_KEY="your_twitter_api_key_here"
TWITTER_API_SECRET="your_twitter_api_secret_here"

# Development
NODE_ENV="development"
PORT=3000

# CMS (Notion)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
